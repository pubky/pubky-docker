#####
# DOCKER COMPOSE
#####

# Full stack on `docker compose up`; use `docker compose --profile backend up` for backend only
COMPOSE_PROFILES=backend,pubky-app

# mainnet or testnet network
NETWORK=testnet # mainnet

#####
# POSTGRES
#####
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_pass
POSTGRES_DB=pubky_homeserver

#####
# CLIENT
#####

# # Testnet
PUBKY_RUNTIME_HOMESERVER=8pinxxgqs41n4aididenw5apqp1urfmzdztr8jt4abrkdn435ewo
PUBKY_RUNTIME_HOMESERVER_URL=http://localhost:6286
PUBKY_RUNTIME_NEXUS_URL=http://localhost:8080
PUBKY_RUNTIME_CDN_URL=http://localhost:8080/static
PUBKY_RUNTIME_TESTNET=true
PUBKY_RUNTIME_DEFAULT_HTTP_RELAY=http://localhost:15412/link/
PUBKY_RUNTIME_PKARR_RELAYS=["https://pkarr.pubky.app","https://pkarr.pubky.org"] # Ignored when using Testnet
PUBKY_RUNTIME_HOMEGATE_URL=http://localhost:6300
PUBKY_ENABLE_PLAUSIBLE=false

# Mainnet
# PUBKY_RUNTIME_HOMESERVER=8pinxxgqs41n4aididenw5apqp1urfmzdztr8jt4abrkdn435ewo
# NEXT_PUBLIC_NEXUS_URL=http://localhost:8080
# NEXT_PUBLIC_TESTNET=false
# NEXT_PUBLIC_DEFAULT_HTTP_RELAY=https://httprelay.staging.pubky.app/link/

